#!/bin/sh
# Pre-commit hook: run cargo fmt, clippy, and prettier on staged files.

export PATH="$HOME/.cargo/bin:$PATH"
set -e

echo "==> Running cargo fmt..."
cargo fmt --all
RUST_FILES=$(git diff --name-only -- '*.rs' || true)
if [ -n "$RUST_FILES" ]; then
  echo "$RUST_FILES" | xargs git add
fi

echo "==> Running cargo clippy..."
cargo clippy --workspace --all-targets --exclude keychainpgp-wasm --exclude keychainpgp-ui -- -D warnings

echo "==> Running prettier on staged frontend files..."
FRONTEND_DIR="crates/keychainpgp-ui/frontend"
FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM -- "$FRONTEND_DIR/src/**" "$FRONTEND_DIR/messages/**" "$FRONTEND_DIR/scripts/**" | grep -E '\.(js|ts|svelte|json|css|html)$' || true)
if [ -n "$FRONTEND_FILES" ]; then
  # Run prettier from the frontend dir so plugins resolve correctly
  # Convert repo-relative paths to frontend-relative paths
  RELATIVE_FILES=$(echo "$FRONTEND_FILES" | sed "s|^$FRONTEND_DIR/||")
  (cd "$FRONTEND_DIR" && echo "$RELATIVE_FILES" | xargs npx prettier --write)
  echo "$FRONTEND_FILES" | xargs git add
fi

echo "==> Pre-commit checks passed."