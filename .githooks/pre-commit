#!/bin/sh
# Pre-commit hook: run cargo fmt, clippy, and prettier on staged files.

export PATH="$HOME/.cargo/bin:$PATH"
set -e

echo "==> Running cargo fmt --check..."
cargo fmt --all -- --check

echo "==> Running cargo clippy..."
cargo clippy --workspace --all-targets --exclude keychainpgp-wasm --exclude keychainpgp-ui -- -D warnings

echo "==> Running prettier on staged frontend files..."
FRONTEND_FILES=$(git diff --cached --name-only --diff-filter=ACM -- 'crates/keychainpgp-ui/frontend/src/**' 'crates/keychainpgp-ui/frontend/messages/**' 'crates/keychainpgp-ui/frontend/scripts/**' | grep -E '\.(js|ts|svelte|json|css|html)$' || true)
if [ -n "$FRONTEND_FILES" ]; then
  npx --prefix crates/keychainpgp-ui/frontend prettier --write $FRONTEND_FILES
  echo "$FRONTEND_FILES" | xargs git add
fi

echo "==> Pre-commit checks passed."